# GTM Intelligence System — Environment Variables
# Copy this file to .env and fill in your values
# Do NOT commit .env to version control

# LLM API Key — supports Groq (free) or xAI Grok or OpenAI
# Get a free Groq key at: https://console.groq.com
GROK_API_KEY=gsk_your_groq_api_key_here

# Optional alternative LLMs (leave blank if not using)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Database (leave blank to use local SQLite)
DATABASE_URL=
